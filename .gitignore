# .gitignore
# Reslava Workflow VSIX Project

# --- Node.js / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
out/
dist/
*.vsix  # Keep ignored; store local copies in ~/vsix-archive/
*.tsbuildinfo

# --- VS Code Extension ---
.vscode-test/
*.code-workspace

# --- Workflow System ---
# Derived state cache (local only)
.wf/cache/
.wf/prompts/

# Auto-generated context summaries (optional to ignore)
# Uncomment if you prefer to regenerate summaries rather than version them
# features/**/*-ctx.md

# Temporary files
*.tmp
*.bak
*~
*.swp

# --- OS Metadata ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
*.sublime-*
.idea/
*.iml

# --- Internal Documentation (excluded from public repo) ---
docs/internal/

# --- Environment & Secrets ---
.env
.env.*
!.env.example
*.key
*.pem

# --- Claude ---
CLAUDE.md
.claude/