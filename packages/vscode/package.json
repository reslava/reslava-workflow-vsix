{
  "name": "loom-vscode",
  "displayName": "Loom",
  "description": "Weave ideas into features with AI — document‑driven workflow for VS Code",
  "version": "0.1.0",
  "publisher": "reslava",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.loom/**"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom-icon.svg"
        }
      ]
    },
    "views": {
      "loom": [
        {
          "id": "loom.threads",
          "name": "Threads"
        }
      ]
    },
    "commands": [
      {
        "command": "loom.refresh",
        "title": "Refresh",
        "category": "Loom",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.weaveIdea",
        "title": "Weave Idea",
        "category": "Loom",
        "icon": "$(lightbulb)"
      },
      {
        "command": "loom.weaveDesign",
        "title": "Weave Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.weavePlan",
        "title": "Weave Plan",
        "category": "Loom",
        "icon": "$(checklist)"
      },
      {
        "command": "loom.finalize",
        "title": "Finalize Document",
        "category": "Loom",
        "icon": "$(check)"
      },
      {
        "command": "loom.rename",
        "title": "Rename Document",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refineDesign",
        "title": "Refine Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.startPlan",
        "title": "Start Plan",
        "category": "Loom",
        "icon": "$(play)"
      },
      {
        "command": "loom.completeStep",
        "title": "Complete Step",
        "category": "Loom",
        "icon": "$(pass)"
      },
      {
        "command": "loom.validate",
        "title": "Validate",
        "category": "Loom",
        "icon": "$(shield)"
      },
      {
        "command": "loom.summarise",
        "title": "Summarise Context",
        "category": "Loom",
        "icon": "$(book)"
      },
      {
        "command": "loom.setGrouping",
        "title": "Set Grouping",
        "category": "Loom",
        "icon": "$(list-tree)"
      },
      {
        "command": "loom.setTextFilter",
        "title": "Filter",
        "category": "Loom",
        "icon": "$(filter)"
      },
      {
        "command": "loom.toggleArchived",
        "title": "Toggle Archived",
        "category": "Loom",
        "icon": "$(archive)"
      },
      {
        "command": "loom.chatNew",
        "title": "New Chat",
        "category": "Loom",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "loom.chatReply",
        "title": "AI Reply",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.promoteToIdea",
        "title": "Promote to Idea",
        "category": "Loom",
        "icon": "$(lightbulb)"
      },
      {
        "command": "loom.promoteToDesign",
        "title": "Promote to Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.promoteToPlan",
        "title": "Promote to Plan",
        "category": "Loom",
        "icon": "$(checklist)"
      },
      {
        "command": "loom.refineIdea",
        "title": "Refine Idea",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refinePlan",
        "title": "Refine Plan",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.doStep",
        "title": "Do Step(s)",
        "category": "Loom",
        "icon": "$(sparkle)"
      },
      {
        "command": "loom.closePlan",
        "title": "Close Plan",
        "category": "Loom",
        "icon": "$(archive)"
      }
    ],
    "configuration": {
      "title": "Loom",
      "properties": {
        "reslava-loom.ai.provider": {
          "type": "string",
          "enum": ["deepseek", "openai"],
          "default": "deepseek",
          "description": "AI provider. DeepSeek is recommended for cost-effective testing."
        },
        "reslava-loom.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the configured AI provider.",
          "markdownDescription": "API key for the configured AI provider. Store securely — do not commit to source control."
        },
        "reslava-loom.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model name override. Leave blank to use the provider default (deepseek-chat / gpt-4o-mini)."
        },
        "reslava-loom.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL override for OpenAI-compatible endpoints. Leave blank to use provider default."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "loom.chatNew",
          "when": "view == loom.threads",
          "group": "navigation@0"
        },
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads",
          "group": "navigation@1"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads",
          "group": "navigation@2"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads",
          "group": "navigation@3"
        },
        {
          "command": "loom.setGrouping",
          "when": "view == loom.threads",
          "group": "navigation@4"
        },
        {
          "command": "loom.setTextFilter",
          "when": "view == loom.threads",
          "group": "navigation@5"
        },
        {
          "command": "loom.toggleArchived",
          "when": "view == loom.threads",
          "group": "navigation@6"
        },
        {
          "command": "loom.refresh",
          "when": "view == loom.threads",
          "group": "navigation@7"
        }
      ],
      "view/item/context": [
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads && viewItem == thread",
          "group": "inline@1"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads && viewItem == thread",
          "group": "inline@2"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads && (viewItem == thread || viewItem == design)",
          "group": "inline@3"
        },
        {
          "command": "loom.summarise",
          "when": "view == loom.threads && (viewItem == weave || viewItem == thread) && loom.aiEnabled",
          "group": "inline@4"
        },
        {
          "command": "loom.finalize",
          "when": "view == loom.threads && viewItem =~ /^(idea|design|loose-idea|loose-design)-temp$/",
          "group": "inline@1"
        },
        {
          "command": "loom.refineDesign",
          "when": "view == loom.threads && viewItem == design",
          "group": "inline@2"
        },
        {
          "command": "loom.startPlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(draft|active)$/",
          "group": "inline@1"
        },
        {
          "command": "loom.doStep",
          "when": "view == loom.threads && viewItem == plan-implementing && loom.aiEnabled",
          "group": "inline@1"
        },
        {
          "command": "loom.completeStep",
          "when": "view == loom.threads && viewItem == plan-implementing",
          "group": "inline@2"
        },
        {
          "command": "loom.validate",
          "when": "view == loom.threads && viewItem == weave",
          "group": "inline@2"
        },
        {
          "command": "loom.chatReply",
          "when": "view == loom.threads && viewItem == chat && loom.aiEnabled",
          "group": "inline@1"
        },
        {
          "command": "loom.promoteToIdea",
          "when": "view == loom.threads && viewItem == chat && loom.aiEnabled",
          "group": "inline@2"
        },
        {
          "command": "loom.promoteToDesign",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea)/ && loom.aiEnabled",
          "group": "inline@3"
        },
        {
          "command": "loom.promoteToPlan",
          "when": "view == loom.threads && viewItem =~ /^(chat|idea|loose-idea|design)/ && loom.aiEnabled",
          "group": "inline@4"
        },
        {
          "command": "loom.refineIdea",
          "when": "view == loom.threads && viewItem =~ /^(idea|loose-idea)/ && loom.aiEnabled",
          "group": "inline@1"
        },
        {
          "command": "loom.refinePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-/ && loom.aiEnabled",
          "group": "inline@2"
        },
        {
          "command": "loom.closePlan",
          "when": "view == loom.threads && viewItem =~ /^plan-(implementing|done)$/ && loom.aiEnabled",
          "group": "inline@3"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@reslava-loom/app": "file:../app",
    "@reslava-loom/core": "file:../core",
    "@reslava-loom/fs": "file:../fs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  }
}