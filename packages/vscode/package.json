{
  "name": "loom-vscode",
  "displayName": "Loom",
  "description": "Weave ideas into features with AI — document‑driven workflow for VS Code",
  "version": "0.1.0",
  "publisher": "reslava",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.loom/**"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "loom",
          "title": "Loom",
          "icon": "media/loom-icon.svg"
        }
      ]
    },
    "views": {
      "loom": [
        {
          "id": "loom.threads",
          "name": "Threads"
        }
      ]
    },
    "commands": [
      {
        "command": "loom.refresh",
        "title": "Loom: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "loom.weaveIdea",
        "title": "Loom: Weave Idea",
        "category": "Loom",
        "icon": "$(lightbulb)"
      },
      {
        "command": "loom.weaveDesign",
        "title": "Loom: Weave Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.weavePlan",
        "title": "Loom: Weave Plan",
        "category": "Loom",
        "icon": "$(checklist)"
      },
      {
        "command": "loom.finalize",
        "title": "Loom: Finalize Document",
        "category": "Loom",
        "icon": "$(check)"
      },
      {
        "command": "loom.rename",
        "title": "Loom: Rename Document",
        "category": "Loom",
        "icon": "$(edit)"
      },
      {
        "command": "loom.refineDesign",
        "title": "Loom: Refine Design",
        "category": "Loom",
        "icon": "$(symbol-structure)"
      },
      {
        "command": "loom.startPlan",
        "title": "Loom: Start Plan",
        "category": "Loom",
        "icon": "$(play)"
      },
      {
        "command": "loom.completeStep",
        "title": "Loom: Complete Step",
        "category": "Loom",
        "icon": "$(pass)"
      },
      {
        "command": "loom.validate",
        "title": "Loom: Validate",
        "category": "Loom",
        "icon": "$(shield)"
      },
      {
        "command": "loom.summarise",
        "title": "Loom: Summarise Context",
        "category": "Loom",
        "icon": "$(book)"
      },
      {
        "command": "loom.setGrouping",
        "title": "Loom: Set Grouping",
        "icon": "$(list-tree)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "loom.weaveIdea",
          "when": "view == loom.threads",
          "group": "navigation@1"
        },
        {
          "command": "loom.weaveDesign",
          "when": "view == loom.threads",
          "group": "navigation@2"
        },
        {
          "command": "loom.weavePlan",
          "when": "view == loom.threads",
          "group": "navigation@3"
        },
        {
          "command": "loom.setGrouping",
          "when": "view == loom.threads",
          "group": "navigation@4"
        },
        {
          "command": "loom.refresh",
          "when": "view == loom.threads",
          "group": "navigation@5"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@reslava-loom/app": "file:../app",
    "@reslava-loom/core": "file:../core",
    "@reslava-loom/fs": "file:../fs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0"
  }
}